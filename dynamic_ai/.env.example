# ---------------------------------------------------------------------------
# Local dev config TEMPLATE. Copy to ".env" and fill in — never put real keys
# in this file (it is the shareable template; .env is gitignored).
# Inside the HA add-on these values come from the add-on settings UI instead.
# ---------------------------------------------------------------------------

# Home Assistant — dev mode only (automatic inside the add-on via SUPERVISOR_TOKEN)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=                 # HA -> Profile -> Security -> Long-lived access tokens -> Create

# LLM keys — in the add-on these come from the settings UI instead
OPENAI_API_KEY=           # required (powers voice + ChatGPT)
ANTHROPIC_API_KEY=        # optional (Claude as the text brain)

# Optional
DEFAULT_TEXT_PROVIDER=openai   # openai | anthropic
VOICE_MODEL=gpt-realtime-2     # OpenAI Realtime model for voice (current flagship, 2026)
VOICE_NAME=marin               # voice timbre (multilingual): marin, cedar, alloy, echo, shimmer, ...
LANGUAGE=                      # force replies + speech into a language, e.g. "nl" for Dutch ("" = auto)
PORT=8099
